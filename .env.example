# DevPulse Configuration Environment Variables

# LLM Backend select: openai | groq | ollama
LLM_BACKEND=ollama

# Optional GitHub Personal Access Token (Raises API rate limits from 60 to 5,000 requests/hr)
# GITHUB_TOKEN=your_github_token_here

# For OpenAI Backend
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# For Groq Backend
# GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=llama-3.1-8b-instant

# For Ollama Backend
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b
